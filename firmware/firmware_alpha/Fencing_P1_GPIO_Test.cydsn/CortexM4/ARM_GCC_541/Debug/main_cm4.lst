  47:main_cm4.c    **** void read_sensors(bool* cap, bool* button) {
  48:main_cm4.c    ****     // read capacitive sensor
  49:main_cm4.c    ****     *cap = CapSense_IsWidgetActive(CapSense_HITSENSOR_WDGT_ID);
  50:main_cm4.c    ****     
  51:main_cm4.c    ****     // read button: ButtonDrive goes low, ButtonSense reads with pullup
  52:main_cm4.c    ****     // read button with input pullup
  53:main_cm4.c    ****     Cy_GPIO_Set(ButtonSense_PORT, ButtonSense_NUM); // important!!!
  54:main_cm4.c    ****     Cy_GPIO_SetDrivemode(ButtonSense_PORT, ButtonSense_NUM, CY_GPIO_DM_PULLUP);
  55:main_cm4.c    ****     // drive other side of button low
  56:main_cm4.c    ****     Cy_GPIO_Clr(ButtonDrive_PORT, ButtonDrive_NUM);
  57:main_cm4.c    ****     Cy_GPIO_SetDrivemode(ButtonDrive_PORT, ButtonDrive_NUM, CY_GPIO_DM_STRONG);
  58:main_cm4.c    ****     
  59:main_cm4.c    ****     CyDelayUs(10); // wait for stability (probably not necessary but you never know)
  60:main_cm4.c    ****     *button = Cy_GPIO_Read(ButtonSense_PORT, ButtonSense_NUM);
  61:main_cm4.c    ****     
  62:main_cm4.c    ****     // disconnect both sides of button
  63:main_cm4.c    ****     Cy_GPIO_SetDrivemode(ButtonDrive_PORT, ButtonDrive_NUM, CY_GPIO_DM_HIGHZ);
  64:main_cm4.c    ****     Cy_GPIO_SetDrivemode(ButtonSense_PORT, ButtonSense_NUM, CY_GPIO_DM_HIGHZ);
  65:main_cm4.c    ****     
  66:main_cm4.c    ****     // wait some time for stuff to stabilize before using capsense again
  67:main_cm4.c    ****     CyDelayUs(10);
  68:main_cm4.c    **** }
