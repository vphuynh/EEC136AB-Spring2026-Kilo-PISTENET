# Fencing_P1_GPIO_Test
# 2026-04-30 01:57:07Z

dont_use_location SMIF -1 -1 0
dont_use_location p4usbcell -1 -1 0
dont_use_location USB -1 -1 0
dont_use_location usbcell -1 -1 0
set_location "ClockGenBlock" CLK_GEN -1 -1 0
set_location "ClockBlock" Clock -1 -1 0
set_location "CPUSS" CPUSS -1 -1 0
set_io "CY_CPUSS_SWJ_SWCLK_TCLK(0)" iocell 6 7
set_io "CY_CPUSS_SWJ_SWDIO_TMS(0)" iocell 6 6
set_io "LED_Pin(0)" iocell 7 1
set_io "\CapSense_1:Cmod(0)\" iocell 7 7
set_io "\CapSense_1:Sns(0)\" iocell 6 2
set_location "\BLE_1:cy_mxs40_ble\" BLE -1 -1 0
set_location "\BLE_1:bless_isr\" interrupt -1 -1 24
set_location "\CapSense_1:IDACMod\" CSIDAC7 -1 -1 0
set_location "\CapSense_1:IDACComp\" CSIDAC7 -1 -1 1
set_location "\CapSense_1:CSD\" CSD -1 -1 0
set_location "\CapSense_1:ISR\" interrupt -1 -1 49
