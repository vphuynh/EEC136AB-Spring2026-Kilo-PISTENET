 516:Generated_Source\PSoC6\pdl\middleware\ble/cy_ble.c **** * \return
 517:Generated_Source\PSoC6\pdl\middleware\ble/cy_ble.c **** *  None
 518:Generated_Source\PSoC6\pdl\middleware\ble/cy_ble.c **** *
 519:Generated_Source\PSoC6\pdl\middleware\ble/cy_ble.c **** *******************************************************************************/
